{
  "all": true,
  "check-coverage": true,
  "branches": 0,
  "functions": 0,
  "lines": 0,
  "statements": 0,
  "reporter": [
    "text-summary",
    "lcov"
  ],
  "reports-dir": "output/coverage",
  "temp-directory": ".tmp/c8",
  "src": [
    "src",
    "scripts"
  ],
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "src/**/*.d.ts",
    "scripts/**/*.json",
    "tests/**"
  ]
}
