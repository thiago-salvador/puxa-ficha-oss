{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "sentry.*.config.ts",
    "playwright*.config.ts",
    "src/app/**/*.{ts,tsx}",
    "scripts/**/*.ts",
    "tests/**/*.test.{ts,tsx}",
    "tests/visual/**/*.spec.ts"
