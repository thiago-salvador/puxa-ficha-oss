# =============================================================================
# Puxa Ficha — variáveis de ambiente
# Copie para .env.local e preencha. NUNCA commite .env.local.
# Em produção (VERCEL_ENV=production) as obrigatórias são validadas em
# src/instrumentation.ts e o boot falha se faltarem.
# =============================================================================

# --- Supabase (app / servidor, leitura) --------------------------------------
# Crie um projeto em https://supabase.com e aplique as migrations de supabase/.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Mesmo projeto, exposto ao browser (Next.js). Mesmos valores dos dois acima.
# O anon key é público por desenho; o service_role NUNCA vai para o browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- Supabase (ingest / scripts, privilegiado) -------------------------------
# Necessário apenas para rodar o pipeline de ingestão de dados, nunca no runtime web.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- URL pública do site -----------------------------------------------------
# Usada em metadata/SEO e em URLs absolutas. Sem barra final.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Observabilidade: Sentry (obrigatório em produção) -----------------------
# NEXT_PUBLIC_SENTRY_DSN=https://...@....ingest.sentry.io/...
# SENTRY_DSN=                       # opcional; server reutiliza o NEXT_PUBLIC_ se vazio
# SENTRY_TRACES_SAMPLE_RATE=0.05
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05
# Upload de source maps no build (opcional, só em CI/deploy):
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# --- Metadata social ---------------------------------------------------------
# NEXT_PUBLIC_X_HANDLE=@puxaficha
# INSTAGRAM_APP_ID=your-instagram-app-id

# --- Revalidação de cache (ISR) ----------------------------------------------
# Segredo para as rotas internas de revalidação. Token longo e aleatório.
# PF_REVALIDATE_SECRET=

# --- Rotas internas / preview ------------------------------------------------
# PF_PREVIEW_TOKEN=defina-um-token-longo-e-aleatorio-com-pelo-menos-24-caracteres
# PF_INTERNAL_TOKEN=defina-um-token-longo-e-aleatorio
# Host próprio com `next start` em HTTPS (na Vercel, VERCEL=1 já basta):
# PF_FORCE_PRODUCTION_SECURITY_HEADERS=1

# --- Quiz --------------------------------------------------------------------
# Salt para hash de IP em links curtos (/api/quiz/short-link). Defina em produção.
# PF_QUIZ_SHORT_LINK_SALT=

# --- Alertas por email -------------------------------------------------------
# NEXT_PUBLIC_ALERTS_EMAIL_ENABLED=false
# RESEND_API_KEY=re_...
# CRON_SECRET=defina-um-token-longo-e-aleatorio
# PF_ALERTS_FROM_EMAIL=Puxa Ficha <alertas@seu-dominio.com>
# PF_ALERTS_TOKEN_SALT=defina-um-salt-longo-e-aleatorio
# PF_ALERTS_IP_SALT=defina-um-salt-longo-e-aleatorio
# PF_ALERTS_TOKEN_ENCRYPTION_KEY=64-caracteres-hex-para-aes-256-gcm

# --- Ingestão de dados (scripts) ---------------------------------------------
# Portal da Transparência (opcional; https://portaldatransparencia.gov.br/api-de-dados)
# TRANSPARENCIA_API_KEY=
# Salt para cpf_hash de doadores (só servidor; não reutilizar outros salts;
# não alterar após a primeira ingestão com hashes persistidos).
# PF_DOADOR_CPF_HASH_SALT=
