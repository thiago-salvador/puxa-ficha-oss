{
  "name": "puxa-ficha",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma cívica de consulta pública sobre candidatos das eleições brasileiras: ficha, comparador e pontos de atenção com fontes visíveis.",
  "license": "Elastic-2.0",
  "homepage": "https://puxaficha.com.br",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thiago-salvador/puxa-ficha.git"
  },
  "bugs": {
    "url": "https://github.com/thiago-salvador/puxa-ficha/issues"
  },
  "author": "Thiago Salvador",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:clean": "rm -rf .next && next dev --turbopack",
    "dev:raw": "next dev --turbopack",
    "build": "next build --turbopack",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "next start",
    "lint": "eslint",
    "lint:spell": "cspell lint --no-progress \"src/app/(site)/privacidade/page.tsx\" \"src/app/(site)/sobre/page.tsx\" src/app/not-found.tsx \"src/app/(site)/page.tsx\" src/app/layout.tsx",
    "lint:spell:ui": "cspell lint --no-progress \"src/app/**/*.tsx\" \"src/components/**/*.tsx\" --exclude \"**/internaltest/**\" --exclude \"**/styleguide/**\" --exclude \"**/preview/**\"",
    "test": "node --import tsx --test tests/**/*.test.ts tests/**/*.test.tsx",
    "test:coverage:raw": "node scripts/run-c8-node26.mjs --config c8.config.json node --import tsx --test --test-force-exit --test-concurrency=1 tests/**/*.test.ts tests/**/*.test.tsx",
    "check:dead-code": "knip --config knip.json --include files,dependencies,unlisted,unresolved,exports --no-progress --max-issues 0",
    "test:a11y": "playwright test tests/visual/a11y.spec.ts",
    "test:visual": "playwright test",
    "test:playwright:launch": "playwright test -c playwright.launch.config.ts",
    "test:visual:editorial": "playwright test tests/visual/editorial-badges.spec.ts",
    "test:visual:editorial:local": "PF_PLAYWRIGHT_EDITORIAL_WEBSERVER=1 PF_BASE_URL=http://127.0.0.1:3000 playwright test -c playwright.editorial.config.ts --project=desktop",
    "test:visual:mobile": "playwright test --project=mobile",
    "test:visual:quiz": "playwright test tests/visual/quiz.spec.ts",
    "test:visual:quiz:mobile": "playwright test --project=mobile tests/visual/quiz.spec.ts",
    "test:visual:quiz-og": "npm run build && playwright test -c playwright.quiz-og.config.ts",
    "check:scripts": "tsc --project tsconfig.scripts.json",
    "audit:public-document-exposure:gate": "tsx scripts/audit-public-document-exposure.ts",
    "audit:public-security-surface:gate": "tsx scripts/audit-public-security-surface.ts",
    "validate:seed": "tsx scripts/validate-seed.ts",
    "apply:factual-fixes:dry-run": "tsx scripts/apply-current-factual-fixes.ts --dry-run",
    "persist:sq": "tsx scripts/persist-sq-candidato.ts",
    "data:recalc-financiamento-doadores": "tsx scripts/recalc-financiamento-maiores-doadores.ts --apply",
    "data:recalc-financiamento-doadores:dry-run": "tsx scripts/recalc-financiamento-maiores-doadores.ts --dry-run"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@sentry/nextjs": "^10.53.1",
    "@supabase/supabase-js": "^2.110.8",
    "@tanstack/react-virtual": "^3.14.2",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.14.2",
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.7.0",
    "next": "^16.2.11",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@cspell/dict-pt-br": "^2.4.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "agent-react-devtools": "^0.4.0",
    "c8": "^11.0.0",
    "cspell": "^10.0.1",
    "csv-parse": "^6.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fallow": "^2.88.3",
    "knip": "^6.15.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "react-devtools-core": "^7.0.1",
    "server-only": "^0.0.1",
    "shadcn": "^4.10.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "$postcss",
    "sharp": "^0.35.3"
  }
}
